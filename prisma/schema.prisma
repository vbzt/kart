generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

enum UserRole {
  CLIENT
  ADMIN
}

model User {
  id        String   @id @default(uuid())  @db.Uuid
  email     String   @unique
  name  String
  cpf       String  @unique
  phone     String
  role      UserRole @default(CLIENT)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  bookings        Booking[]
  subscriptions   Subscription[]
  paymentsCreated Payment[] @relation("PaymentCreator")

  @@index([email])
  @@index([cpf])
  @@index([role])
}




model Service {
  id               String    @id @default(uuid())  @db.Uuid
  title            String
  description      String?   @db.Text
  priceCents            Int
  promotionalPriceCents Int?
  isPromotional         Boolean @default(false)
  durationMinutes  Int
  maxCapacity      Int       @default(4)
  priceType        PriceType @default(INDIVIDUAL)
  isActive         Boolean   @default(true)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  bookings   Booking[]
  planAccess PlanServiceAccess[]

  @@index([isActive])
  @@index([isPromotional])
}

enum PriceType {
  INDIVIDUAL
  GROUP
}

model Plan {
  id              String   @id @default(uuid())  @db.Uuid
  name            String
  description     String?  @db.Text
  creditsPerMonth Int
  priceCents Int
  isActive        Boolean  @default(true)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  subscriptions Subscription[]
  serviceAccess PlanServiceAccess[]

  @@index([isActive])
}

model PlanServiceAccess {
  id        String @id @default(uuid())  @db.Uuid
  planId    String @db.Uuid
  serviceId String @db.Uuid

  createdAt DateTime @default(now()) 

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([planId, serviceId])
  @@index([planId])
  @@index([serviceId])
}

model Booking {
  id             String   @id @default(uuid()) @db.Uuid
  serviceId      String   @db.Uuid
  userId         String   @db.Uuid
  subscriptionId String?  @db.Uuid

  bookingDate    DateTime @db.Date
  bookingTime    DateTime 
  numberOfPeople Int      @default(1)

  status BookingStatus @default(PENDING)

  originalPriceCents Int?
  discountCents      Int @default(0)
  finalPriceCents    Int?

  couponCode    String?
  howDidYouKnow String?
  experienceLevel ExperienceLevel?

  notes String? @db.Text


  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  user      User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  payments            Payment[]
  creditTransactions  CreditTransaction[]

  @@index([userId])
  @@index([serviceId])
  @@index([subscriptionId])
  @@index([status])
  @@index([bookingDate, bookingTime])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

enum ExperienceLevel {
  BEGINNER
  EXPERIENCED
}

model Payment {
  id             String  @id @default(uuid())  @db.Uuid
  bookingId      String? @db.Uuid
  subscriptionId String? @db.Uuid

  amountCents Int
  currency    String @default("BRL")

  status      PaymentStatus @default(PENDING)
  paymentType PaymentType

  provider          String
  providerPaymentId String?
  providerMetadata  Json?

  qrCodeUrl  String?
  paymentUrl String?
  receiptUrl String?

  webhookEvents Json[] @default([])

  paidAt    DateTime? 
  createdBy String?   @db.Uuid
  notes     String?   @db.Text

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  creator      User?         @relation("PaymentCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider, providerPaymentId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  PAID
  REJECTED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  SUBSCRIPTION
}


model Subscription {
  id       String @id @default(uuid())  @db.Uuid
  userId   String @db.Uuid
  planId   String @db.Uuid

  status       SubscriptionStatus @default(PENDING)
  creditsTotal Int

  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  bookings           Booking[]
  payments           Payment[]
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

// ============================================
// CREDITS
// ============================================

model CreditTransaction {
  id             String @id @default(uuid())  @db.Uuid
  subscriptionId String @db.Uuid
  bookingId      String? @db.Uuid
  type         CreditTransactionType
  description  String? @db.Text

  createdAt DateTime @default(now()) 

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
}

enum CreditTransactionType {
  PURCHASE
  USE
  REFUND
  EXPIRE
  ADJUSTMENT
}


model Coupon {
  id            String @id @default(uuid())  @db.Uuid
  code          String @unique
  discountType  DiscountType
  discountValue Int

  isActive    Boolean @default(true)
  validFrom   DateTime? 
  validUntil  DateTime? 
  maxUses     Int?
  currentUses Int @default(0)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  @@index([code])
  @@index([isActive])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}


model BusinessHour {
  id        String @id @default(uuid())  @db.Uuid
  dayOfWeek Int
  isOpen    Boolean @default(true)
  openTime  DateTime @db.Time(6)
  closeTime DateTime @db.Time(6)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  @@unique([dayOfWeek])
}

model BlockedPeriod {
  id          String @id @default(uuid())  @db.Uuid
  title       String
  description String? @db.Text

  startDate DateTime @db.Date
  startTime DateTime @db.Time(6)
  endDate   DateTime @db.Date
  endTime   DateTime @db.Time(6)

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  @@index([startDate, endDate])
  @@index([isActive])
}

model Setting {
  id          String @id @default(uuid())  @db.Uuid
  key         String @unique @db.VarChar(100)
  value       String? @db.Text
  description String? @db.Text

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 

  @@index([key])
}
